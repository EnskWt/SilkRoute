<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<!-- NuGet package metadata -->
		<PackageId>SilkRoute</PackageId>
		<Version>2.0.0</Version>
		<Authors>Ihor Nykolaichuk</Authors>
		<Description>
			Provides a declarative, interface-driven approach to generating and registering microservice clients, streamlining API calls, centralizing configuration, and eliminating boilerplate setup.
		</Description>
		<PackageIcon>package_icon.png</PackageIcon>
		<PackageTags>microservice;http;api</PackageTags>
		<RepositoryUrl>https://github.com/EnskWt/SilkRoute</RepositoryUrl>
		<PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Castle.Core" Version="5.2.1" />
		<PackageReference Include="Castle.Core.AsyncInterceptor" Version="2.1.0" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
	</ItemGroup>

	<ItemGroup>
		<None Include="NugetResources\package_icon.png" Pack="true" PackagePath="" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Internal\ActionReturn\" />
	</ItemGroup>

</Project>
